ion":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"desc":"3073","fix":"3074"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},[631,2552],"(\n        <div className=\"group relative z-content w-full shrink-0 overflow-hidden bg-bg-secondary shadow-[0_2px_10px_0_rgba(0,0,0,0.4)]\">\n            {/* Banner (Image or Color) */}\n            {banner && !loading && (\n                <div className=\"relative h-[135px] w-full shrink-0 overflow-hidden\">\n                    <ServerBannerMedia\n                        alt={name}\n                        banner={banner}\n                        imageClassName=\"transition-transform duration-500\"\n                    />\n                    <div className=\"absolute inset-0 bg-black/30\" />\n                </div>\n            )}\n\n            <div\n                className={cn(\n                    'relative z-content flex h-12 items-center gap-1.5 px-4',\n                    banner && 'absolute bottom-0',\n                )}\n            >\n                {verified && (\n                    <BadgeCheck\n                        className={cn(\n                            'shrink-0',\n                            loading\n                                ? 'text-muted-foreground'\n                                : banner\n                                  ? 'text-white'\n                                  : 'text-primary',\n                        )}\n                        size={18}\n                        strokeWidth={2.5}\n                    />\n                )}\n                <Text\n                    className={cn(\n                        'truncate text-[15px] drop-shadow-lg transition-colors',\n                        loading\n                            ? 'text-muted-foreground'\n                            : banner\n                              ? 'text-white'\n                              : 'text-foreground',\n                    )}\n                    weight=\"bold\"\n                >\n                    {loading ? 'Loading...' : name}\n                </Text>\n            </div>\n        </div>\n    )",[5577,5704],"fullScreen\n            noPadding\n            isOpen={isOpen}\n            title=\"Server Discovery\"\n            onClose={onClose}",{"desc":"3075","fix":"3076"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"kind":"3069","justification":"3070"},{"fix":"3077","messageId":"3078","data":"3079","desc":"3080"},{"kind":"3069","justification":"3070"},{"fix":"3081","messageId":"3078","data":"3082","desc":"3080"},{"kind":"3069","justification":"3070"},{"fix":"3083","messageId":"3078","data":"3084","desc":"3080"},{"kind":"3069","justification":"3070"},{"fix":"3085","messageId":"3078","data":"3086","desc":"3080"},{"kind":"3069","justification":"3070"},{"fix":"3087","messageId":"3078","data":"3088","desc":"3080"},{"kind":"3069","justification":"3070"},{"fix":"3089","messageId":"3078","data":"3090","desc":"3080"},{"kind":"3069","justification":"3070"},"directive","","Update the dependencies array to be: [selectedChannelId, selectedServerId, selectedFriendId, clearChannelPings, deletePing, messages, pings.pings]",{"range":"3091","text":"3092"},"Update the dependencies array to be: [location.pathname, params.serverId, params.channelId, params.userId, params.messageId, navigate, dispatch, selectedServerId, selectedChannelId]",{"range":"3093","text":"3094"},"Update the dependencies array to be: [selectedServerId, me.serverSettings.order, dispatch, openedFolders]",{"range":"3095",