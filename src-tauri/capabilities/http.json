{
  "identifier": "http-scope",
  "description": "http scope",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://rolling.catfla.re/**" },
        { "url": "http://127.0.0.1:3000/**" },
        { "url": "http://localhost:3000/**" }
      ]
    }
  ]
}
